# pnpm behaviour for a TypeScript monorepo
strict-peer-dependencies=false
auto-install-peers=true
# Never block CI/non-interactive shells on the node_modules purge prompt.
confirm-modules-purge=false
# Hoist common tooling so editors/CI resolve them at the root.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*typescript*
