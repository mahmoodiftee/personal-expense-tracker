# ---- Runtime ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed web origins for CORS.
CORS_ORIGINS=http://localhost:3000

# ---- API ----
API_GLOBAL_PREFIX=api
API_DEFAULT_VERSION=1

# ---- Database (MongoDB Atlas) ----
# Use a local mongo for dev (docker-compose) or an Atlas SRV string in prod.
MONGODB_URI=mongodb://localhost:27017/finance
MONGODB_DB_NAME=finance

# ---- Auth (phase 1.5) ----
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- Observability ----
LOG_LEVEL=debug

# ---- AI (phase 2 — leave blank until enabled) ----
AI_PROVIDER=
AI_API_KEY=
