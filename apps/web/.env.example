# Base URL of the backend API (server-side & build-time).
API_BASE_URL=http://localhost:4000/api/v1

# Public base URL exposed to the browser (client-side fetches).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# App metadata
NEXT_PUBLIC_APP_NAME=Finance

# Optional dev user id for API calls until JWT auth is wired (must match a seeded user).
# NEXT_PUBLIC_DEMO_USER_ID=
